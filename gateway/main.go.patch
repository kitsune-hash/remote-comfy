Add these routes before the existing routes:

	// ComfyUI Proxy (when COMFY_URL is set)
	comfyURL := getEnv("COMFY_URL", "")
	if comfyURL != "" {
		proxyHandler := handlers.NewProxyHandler(comfyURL)
		
		// Proxy all ComfyUI API endpoints
		r.Any("/api/*path", func(c *gin.Context) {
			path := c.Param("path")
			// Skip our custom endpoints
			if strings.HasPrefix(path, "/workflow") || strings.HasPrefix(path, "/worker") || path == "/health" {
				c.Next()
				return
			}
			proxyHandler.ProxyHTTP(c)
		})
		
		// WebSocket proxy
		r.GET("/ws", proxyHandler.ProxyWS)
		
		log.Printf("ComfyUI proxy enabled: %s", comfyURL)
	}
